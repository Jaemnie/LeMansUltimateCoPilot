<UserControl x:Class="LeMansUltimateCoPilot.Overlay.DeltaDistance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="160" Height="50">

    <Border CornerRadius="12"
            Background="#44000000"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="16,8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

            <!-- Delta value (e.g. +0.342 or -0.521) -->
            <TextBlock x:Name="DeltaText"
                       Text="---"
                       FontFamily="Segoe UI"
                       FontSize="22"
                       FontWeight="Black"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       LetterSpacing="-1">
                <TextBlock.Foreground>
                    <SolidColorBrush x:Name="DeltaBrush" Color="#CCFFFFFF"/>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- "vs REF" label -->
            <TextBlock x:Name="SubLabel"
                       Text="vs REF"
                       FontFamily="Segoe UI"
                       FontSize="8"
                       FontWeight="SemiBold"
                       Foreground="#66FFFFFF"
                       HorizontalAlignment="Center"
                       LetterSpacing="2"/>
        </StackPanel>
    </Border>
</UserControl>
