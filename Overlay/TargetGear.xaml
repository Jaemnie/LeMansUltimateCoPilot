<UserControl x:Class="LeMansUltimateCoPilot.Overlay.TargetGear"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80" Height="80">

    <UserControl.Resources>
        <!-- Pulse scale animation when gear changes -->
        <Storyboard x:Key="PulseAnimation" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="GearTransform"
                Storyboard.TargetProperty="ScaleX"
                From="1.0" To="1.5"
                Duration="0:0:0.12"
                AutoReverse="True"/>
            <DoubleAnimation
                Storyboard.TargetName="GearTransform"
                Storyboard.TargetProperty="ScaleY"
                From="1.0" To="1.5"
                Duration="0:0:0.12"
                AutoReverse="True"/>
        </Storyboard>

        <!-- Fade-out animation for alert text -->
        <Storyboard x:Key="AlertFadeOut">
            <DoubleAnimation
                Storyboard.TargetName="AlertBorder"
                Storyboard.TargetProperty="Opacity"
                From="1.0" To="0.0"
                BeginTime="0:0:1.2"
                Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid>

        <!-- Gear number -->
        <TextBlock x:Name="GearText"
                   Text="0"
                   FontFamily="Segoe UI"
                   FontSize="52"
                   FontWeight="Black"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center">
            <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
            <TextBlock.RenderTransform>
                <ScaleTransform x:Name="GearTransform" ScaleX="1" ScaleY="1"/>
            </TextBlock.RenderTransform>
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="1" Opacity="0.9"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Shift alert overlay (shown above gear number) -->
        <Border x:Name="AlertBorder"
                Opacity="0"
                CornerRadius="6"
                Padding="8,3"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,-28,0,0">
            <Border.Background>
                <SolidColorBrush x:Name="AlertBackground" Color="#FFFF5252"/>
            </Border.Background>
            <TextBlock x:Name="AlertText"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="White"
                       TextAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
