<UserControl x:Class="LeMansUltimateCoPilot.Overlay.GhostSteering"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180" Height="100">

    <Canvas x:Name="SteeringCanvas" Width="180" Height="100">

        <!-- Glass background pill -->
        <Border Canvas.Left="0" Canvas.Top="10"
                Width="180" Height="80"
                CornerRadius="40"
                Background="#22000000"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
        </Border>

        <!-- Reference arc (drawn in code-behind as Path) -->
        <Path x:Name="RefArc"
              Stroke="#88FFFFFF"
              StrokeThickness="3"
              StrokeDashArray="4 3"
              StrokeEndLineCap="Round"
              StrokeStartLineCap="Round"/>

        <!-- My steering arc (drawn in code-behind as Path) -->
        <Path x:Name="MyArc"
              StrokeThickness="4"
              StrokeEndLineCap="Round"
              StrokeStartLineCap="Round">
            <Path.Stroke>
                <SolidColorBrush x:Name="MyArcBrush" Color="#FF00E676"/>
            </Path.Stroke>
        </Path>

        <!-- Center hub dot -->
        <Ellipse Canvas.Left="85" Canvas.Top="68"
                 Width="10" Height="10"
                 Fill="#88FFFFFF">
            <Ellipse.Effect>
                <DropShadowEffect Color="White" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
            </Ellipse.Effect>
        </Ellipse>

    </Canvas>
</UserControl>
